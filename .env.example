GRAPH_API_VERSION=v23.0
META_APP_ID=replace_with_meta_app_id
META_APP_SECRET=replace_with_meta_app_secret
FB_USER_ACCESS_TOKEN=replace_with_short_lived_or_long_lived_user_access_token
FB_PAGE_ID=176747645744060
# Use a long-lived Facebook Page Access Token, not a short-lived user token.
# Required permissions: pages_manage_posts and pages_read_engagement.
FB_PAGE_ACCESS_TOKEN=replace_with_long_lived_page_access_token
FB_POST_INTERVAL_MINUTES=240
FB_MAX_POSTS_PER_RUN=1
FB_DRY_RUN=false
